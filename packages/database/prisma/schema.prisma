generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector"), uuidOssp(map: "uuid-ossp")]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  CITIZEN
  ADVOCATE
  LAW_FIRM
  STUDENT
  RESEARCHER
  BUSINESS
  GOVERNMENT
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum CaseStatus {
  DRAFT
  ACTIVE
  PENDING
  CLOSED
  ARCHIVED
}

enum CasePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum DocumentType {
  LEGAL_NOTICE
  AFFIDAVIT
  RENTAL_AGREEMENT
  SALE_AGREEMENT
  EMPLOYMENT_AGREEMENT
  NDA
  GIFT_DEED
  WILL
  CONSUMER_COMPLAINT
  POLICE_COMPLAINT
  RTI_APPLICATION
  COURT_PETITION
  CONTRACT
  OTHER
}

enum DocumentStatus {
  DRAFT
  REVIEW
  FINAL
  SIGNED
  ARCHIVED
}

enum CourtType {
  SUPREME_COURT
  HIGH_COURT
  DISTRICT_COURT
  TRIBUNAL
  CONSUMER_FORUM
}

enum LegislationCategory {
  CONSTITUTION
  CRIMINAL
  CIVIL
  CORPORATE
  TAX
  LABOUR
  PROPERTY
  FAMILY
  IT
  CONSUMER
  ENVIRONMENTAL
  RTI
  MOTOR_VEHICLES
  OTHER
}

enum SubscriptionPlan {
  FREE
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  TRIAL
}

enum NotificationType {
  APPOINTMENT
  CASE_UPDATE
  DOCUMENT
  PAYMENT
  SYSTEM
  AI_ALERT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

// ─── User & Auth ─────────────────────────────────────────────────────────────

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  phone         String?    @unique
  passwordHash  String?
  role          UserRole   @default(CITIZEN)
  status        UserStatus @default(PENDING_VERIFICATION)
  emailVerified Boolean    @default(false)
  phoneVerified Boolean    @default(false)
  googleId      String?    @unique
  avatarUrl     String?
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  profile            Profile?
  advocateProfile    AdvocateProfile?
  refreshTokens      RefreshToken[]
  otpCodes           OtpCode[]
  cases              Case[]              @relation("ClientCases")
  advocateCases      Case[]              @relation("AdvocateCases")
  conversations      Conversation[]
  documents          Document[]
  bookmarks          Bookmark[]
  annotations        Annotation[]
  clientAppointments Appointment[]       @relation("ClientAppointments")
  advocateAppointments Appointment[]     @relation("AdvocateAppointments")
  reviewsGiven       Review[]            @relation("ReviewsGiven")
  reviewsReceived    Review[]            @relation("ReviewsReceived")
  notifications      Notification[]
  subscriptions      Subscription[]
  payments           Payment[]
  auditLogs          AuditLog[]
  savedResearch      SavedResearch[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Profile {
  id          String   @id @default(uuid())
  userId      String   @unique
  firstName   String
  lastName    String
  dateOfBirth DateTime?
  gender      String?
  address     String?
  city        String?
  state       String?
  pincode     String?
  bio         String?
  languages   String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model AdvocateProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  barCouncilNumber   String             @unique
  barCouncilState    String
  enrollmentYear     Int
  practiceAreas      String[]           @default([])
  experience         Int                @default(0)
  consultationFee    Decimal            @default(0) @db.Decimal(10, 2)
  biography          String?
  education          Json?
  certifications     Json?
  languages          String[]           @default([])
  verificationStatus VerificationStatus @default(PENDING)
  isAvailable        Boolean            @default(true)
  rating             Decimal            @default(0) @db.Decimal(3, 2)
  reviewCount        Int                @default(0)
  totalConsultations Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  availability AdvocateAvailability[]

  @@index([verificationStatus])
  @@index([practiceAreas])
  @@map("advocate_profiles")
}

model AdvocateAvailability {
  id          String   @id @default(uuid())
  advocateId  String
  dayOfWeek   Int
  startTime   String
  endTime     String
  isAvailable Boolean  @default(true)

  advocate AdvocateProfile @relation(fields: [advocateId], references: [id], onDelete: Cascade)

  @@map("advocate_availability")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("refresh_tokens")
}

model OtpCode {
  id        String   @id @default(uuid())
  userId    String?
  phone     String?
  email     String?
  code      String
  purpose   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, code])
  @@index([email, code])
  @@map("otp_codes")
}

// ─── Legal Cases ─────────────────────────────────────────────────────────────

model Case {
  id          String       @id @default(uuid())
  caseNumber  String       @unique @default(uuid())
  title       String
  description String?
  status      CaseStatus   @default(DRAFT)
  priority    CasePriority @default(MEDIUM)
  category    String?
  clientId    String
  advocateId  String?
  courtName   String?
  courtType   CourtType?
  filingDate  DateTime?
  nextHearing DateTime?
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  client    User          @relation("ClientCases", fields: [clientId], references: [id])
  advocate  User?         @relation("AdvocateCases", fields: [advocateId], references: [id])
  documents Document[]
  timeline  CaseTimeline[]
  notes     CaseNote[]

  @@index([clientId])
  @@index([advocateId])
  @@index([status])
  @@map("cases")
}

model CaseTimeline {
  id          String   @id @default(uuid())
  caseId      String
  title       String
  description String?
  eventDate   DateTime
  createdAt   DateTime @default(now())

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@map("case_timeline")
}

model CaseNote {
  id        String   @id @default(uuid())
  caseId    String
  authorId  String
  content   String
  isPrivate Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@map("case_notes")
}

// ─── Documents ───────────────────────────────────────────────────────────────

model Document {
  id          String         @id @default(uuid())
  title       String
  type        DocumentType
  status      DocumentStatus @default(DRAFT)
  content     String?        @db.Text
  fileUrl     String?
  fileSize    Int?
  mimeType    String?
  userId      String
  caseId      String?
  version     Int            @default(1)
  metadata    Json?
  aiGenerated Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user User  @relation(fields: [userId], references: [id])
  case Case? @relation(fields: [caseId], references: [id])

  @@index([userId])
  @@index([type])
  @@map("documents")
}

// ─── AI Conversations ────────────────────────────────────────────────────────

model Conversation {
  id        String   @id @default(uuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AIMessage[]

  @@index([userId])
  @@map("conversations")
}

model AIMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String
  content        String   @db.Text
  citations      Json?
  metadata       Json?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("ai_messages")
}

// ─── Legal Knowledge Base ───────────────────────────────────────────────────

model ConstitutionArticle {
  id          String   @id @default(uuid())
  articleNumber String @unique
  title       String
  content     String   @db.Text
  part        String?
  chapter     String?
  isFundamentalRight Boolean @default(false)
  isFundamentalDuty  Boolean @default(false)
  isDirectivePrinciple Boolean @default(false)
  amendments  Json?
  embedding   Unsupported("vector(1536)")?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([articleNumber])
  @@map("constitution_articles")
}

model Legislation {
  id          String              @id @default(uuid())
  title       String
  shortTitle  String?
  actNumber   String?
  year        Int?
  category    LegislationCategory
  content     String              @db.Text
  sections    Json?
  amendments  Json?
  isActive    Boolean             @default(true)
  embedding   Unsupported("vector(1536)")?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([category])
  @@index([shortTitle])
  @@map("legislations")
}

model Judgment {
  id          String    @id @default(uuid())
  title       String
  citation    String    @unique
  court       CourtType
  courtName   String?
  judges      String[]  @default([])
  bench       String?
  caseNumber  String?
  petitioner  String?
  respondent  String?
  judgmentDate DateTime?
  year        Int?
  subject     String?
  statutes    String[]  @default([])
  summary     String?   @db.Text
  fullText    String?   @db.Text
  isLandmark  Boolean   @default(false)
  isConstitutionalBench Boolean @default(false)
  embedding   Unsupported("vector(1536)")?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bookmarks   Bookmark[]
  annotations Annotation[]

  @@index([court])
  @@index([year])
  @@index([subject])
  @@index([isLandmark])
  @@map("judgments")
}

model Bookmark {
  id         String   @id @default(uuid())
  userId     String
  judgmentId String?
  legislationId String?
  articleId  String?
  notes      String?
  createdAt  DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  judgment  Judgment?  @relation(fields: [judgmentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bookmarks")
}

model Annotation {
  id         String   @id @default(uuid())
  userId     String
  judgmentId String
  highlight  String
  note       String?
  startOffset Int?
  endOffset  Int?
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  judgment Judgment @relation(fields: [judgmentId], references: [id], onDelete: Cascade)

  @@map("annotations")
}

model SavedResearch {
  id        String   @id @default(uuid())
  userId    String
  title     String
  query     String
  results   Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("saved_research")
}

// ─── Appointments & Reviews ──────────────────────────────────────────────────

model Appointment {
  id          String            @id @default(uuid())
  clientId    String
  advocateId  String
  scheduledAt DateTime
  duration    Int               @default(30)
  status      AppointmentStatus @default(SCHEDULED)
  type        String            @default("video")
  meetingUrl  String?
  notes       String?
  fee         Decimal?          @db.Decimal(10, 2)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  client   User @relation("ClientAppointments", fields: [clientId], references: [id])
  advocate User @relation("AdvocateAppointments", fields: [advocateId], references: [id])
  payment  Payment?

  @@index([clientId])
  @@index([advocateId])
  @@index([scheduledAt])
  @@map("appointments")
}

model Review {
  id         String   @id @default(uuid())
  reviewerId String
  advocateId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  reviewer User @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  advocate User @relation("ReviewsReceived", fields: [advocateId], references: [id])

  @@index([advocateId])
  @@map("reviews")
}

// ─── Subscriptions & Payments ────────────────────────────────────────────────

model Subscription {
  id        String             @id @default(uuid())
  userId    String
  plan      SubscriptionPlan   @default(FREE)
  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime           @default(now())
  endDate   DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscriptions")
}

model Payment {
  id            String        @id @default(uuid())
  userId        String
  appointmentId String?       @unique
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("INR")
  status        PaymentStatus @default(PENDING)
  gatewayRef    String?
  metadata      Json?
  createdAt     DateTime      @default(now())

  user        User         @relation(fields: [userId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([userId])
  @@map("payments")
}

// ─── Notifications & Audit ───────────────────────────────────────────────────

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  resource  String
  resourceId String?
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── CMS & Blog ──────────────────────────────────────────────────────────────

model BlogPost {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   @db.Text
  coverImage  String?
  author      String
  tags        String[] @default([])
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@map("blog_posts")
}

model GovernmentNotification {
  id          String   @id @default(uuid())
  title       String
  ministry    String?
  gazetteRef  String?
  content     String   @db.Text
  publishedAt DateTime
  category    String?
  createdAt   DateTime @default(now())

  @@index([publishedAt])
  @@map("government_notifications")
}
